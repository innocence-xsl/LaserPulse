# ============================================================
# Python cache and bytecode
# ============================================================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Python packaging / build outputs
# ============================================================
build/
dist/
*.egg-info/
.eggs/

# ============================================================
# Test and coverage outputs
# ============================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ============================================================
# Jupyter / notebooks
# ============================================================
.ipynb_checkpoints/

# ============================================================
# IDE and editor files
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Local run outputs
# Keep generated figures/data out of Git by default.
# Important input data should be stored in tracked data/config folders.
# ============================================================
outputs/
figures/
logs/

# Temporary files
*.tmp
*.bak
